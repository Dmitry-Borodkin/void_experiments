{ v_import("mainline.void"); }
{ v_enable_mainline(); }
//---------------------------------------------------------------------
{
    v_import("cstdio.void");

    v_import("../memory_policy.void");
}


//---------------------------------------------------------------------
{ v_import("stack_trace.void"); }
{ voidc_enable_stack_trace(); }


//---------------------------------------------------------------------
namespace .immer
{
    #do (instantiate_default_memory_policy())

    policy = default_memory_policy;

    #do (policy.heap.instantiate_optimized(777))

    heap = policy.heap.optimized(777).heap;

//---------------------------------------------------------------------
}   //- namespace .immer


{
    heap = immer.heap;

    p = (heap.allocate(sizeof(int[7])) : *int);

    printf("p: %p\n", p);

    heap.deallocate(sizeof(int[7]), p);
}







