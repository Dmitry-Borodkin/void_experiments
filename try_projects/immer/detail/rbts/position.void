{'unit_defn_list'

  namespace position(NodeT)
  {
    struct empty_leaf_pos;

    #if (v_guard_ns(empty_leaf_pos))

      struct empty_leaf_pos
      {
          node_: *NodeT;
      };

      empty_leaf_pos.node_t = NodeT;

