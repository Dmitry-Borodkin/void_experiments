              }
          }

        'unit_defn_list'}

      }     //- namespace empty_leaf_pos


      alwaysinline
      make_empty_leaf_pos: (node: *NodeT) ~> empty_leaf_pos  =  { v_assert(node); {node} };

    #endif

  }     //- namespace position(NodeT)

'unit_defn_list'}


//---------------------------------------------------------------------
//- leaf_pos
//---------------------------------------------------------------------
#define instantiate_leaf_pos: (NodeT: v_static_type_t)
{'unit_defn_list'

  namespace position(NodeT)
  {
    struct leaf_pos;

    #if (v_guard_ns(leaf_pos))

      struct leaf_pos
      {
          node_: *NodeT;
          size_: size_t;
      };

      leaf_pos.node_t = NodeT;
      leaf_pos.B      = NodeT.bits;
      leaf_pos.BL     = NodeT.bits_leaf;

      alwaysinline
      (_.index()): (leaf_pos, idx: size_t) ~> count_t  =  idx & mask(leaf_pos.BL);

      alwaysinline
      (_.subindex()): (leaf_pos, idx: size_t) ~> count_t  =  idx;

      alwaysinline
      (_.count): (pos: leaf_pos) ~> count_t  =  pos.index(pos.size_ -1) + 1;

      alwaysinline
      (_.node): (pos: leaf_pos) ~> *NodeT  =  pos.node_;

      alwaysinline
      (_.shift): (leaf_pos) ~> shift_t  =  0;

      alwaysinline
      (_.size): (pos: leaf_pos) ~> size_t  =  pos.size_;


      namespace leaf_pos
      {
        #define instantiate_visit: (Vis: v_static_namespace_t, ArgsT: v_static_type_t, RetT: v_static_type_t)
        {'unit_defn_list'

          #do (Vis.instantiate_visit_leaf(struct {leaf_pos; ArgsT;}, RetT))

          namespace position_args(leaf_pos, Vis, ArgsT, RetT)
          {
              alwaysinline
              visit: (pos: leaf_pos, args: ArgsT) ~> RetT
              {
                  ns = visitor_args(Vis, struct {leaf_pos; ArgsT;}, RetT);

                  return  ns.visit_leaf({pos, args});
              }
          }

        'unit_defn_list'}

      }     //- namespace leaf_pos


      alwaysinline
      make_leaf_pos: (node: *NodeT, size: size_t) ~> leaf_pos  =
      {
          v_assert(node);
          v_assert(size > 0);
          {node, size}
      };

    #endif

  }     //- namespace position(NodeT)

'unit_defn_list'}


//---------------------------------------------------------------------
//- leaf_sub_pos
//---------------------------------------------------------------------
#define instantiate_leaf_sub_pos: (NodeT: v_static_type_t)
{'unit_defn_list'

  namespace position(NodeT)
  {
    struct leaf_sub_pos;

    #if (v_guard_ns(leaf_sub_pos))

      struct leaf_sub_pos
      {
          node_:  *NodeT;
          count_: count_t;
      };

      leaf_sub_pos.node_t = NodeT;
      leaf_sub_pos.B      = NodeT.bits;
      leaf_sub_pos.BL     = NodeT.bits_leaf;

      alwaysinline
      (_.index()): (leaf_sub_pos, idx: size_t) ~> count_t  =  idx & mask(leaf_sub_pos.BL);

      alwaysinline
      (_.subindex()): (leaf_sub_pos, idx: size_t) ~> count_t  =  idx;

      alwaysinline
      (_.count): (pos: leaf_sub_pos) ~> count_t  =  pos.count_;

      alwaysinline
      (_.node): (pos: leaf_sub_pos) ~> *NodeT  =  pos.node_;

      alwaysinline
      (_.shift): (leaf_sub_pos) ~> shift_t  =  0;

      alwaysinline
      (_.size): (pos: leaf_sub_pos) ~> size_t  =  pos.count_;


      namespace leaf_sub_pos
      {
        #define instantiate_visit: (Vis: v_static_namespace_t, ArgsT: v_static_type_t, RetT: v_static_type_t)
        {'unit_defn_list'

          #do (Vis.instantiate_visit_leaf(struct {leaf_sub_pos; ArgsT;}, RetT))

          namespace position_args(leaf_sub_pos, Vis, ArgsT, RetT)
          {
              alwaysinline
              visit: (pos: leaf_sub_pos, args: ArgsT) ~> RetT
              {
                  ns = visitor_args(Vis, struct {leaf_sub_pos; ArgsT;}, RetT);

                  return  ns.visit_leaf({pos, args});
              }
          }

        'unit_defn_list'}

      }     //- namespace leaf_sub_pos


      alwaysinline
      make_leaf_sub_pos: (node: *NodeT, count: count_t) ~> leaf_sub_pos  =
      {
          v_assert(node);
          v_assert(count <= branches(NodeT.bits_leaf));
          {node, count}
      };

    #endif

  }     //- namespace position(NodeT)

'unit_defn_list'}


