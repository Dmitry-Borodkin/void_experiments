      (_.count): (empty_leaf_pos) ~> count_t  =  0;

      alwaysinline
      (_.node): (pos: empty_leaf_pos) ~> *NodeT  =  pos.node_;

      alwaysinline
      (_.shift): (empty_leaf_pos) ~> shift_t  =  0;

      alwaysinline
      (_.size): (empty_leaf_pos) ~> size_t  =  0;


      namespace empty_leaf_pos
      {
        #define instantiate_visit: (Vis: v_static_namespace_t, ArgsT: v_static_type_t, RetT: v_static_type_t)
        {'unit_defn_list'

