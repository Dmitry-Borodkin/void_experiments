{ voidc_import("libvoidc.void"); }
{ voidc_make_header("position"); }
//---------------------------------------------------------------------
{
    v_export_import("bits.void");
    v_export_import("../util.void");
}


//---------------------------------------------------------------------
{ v_import("stack_trace.void"); }
{ voidc_enable_stack_trace(); }


//---------------------------------------------------------------------
//- <immer/detail/rbts/position.hpp>
//---------------------------------------------------------------------
namespace .immer {
namespace detail {
namespace rbts {

//---------------------------------------------------------------------
#define bits:      [bits_t](Pos: v_static_type_t) ~> bits_t  =  Pos.node_t.bits;
#define bits_leaf: [bits_t](Pos: v_static_type_t) ~> bits_t  =  Pos.node_t.bits_leaf;

#define node_type: (Pos: v_static_type_t) ~> v_static_type_t  =  Pos.node_t;


//---------------------------------------------------------------------
#define position: (NodeT: v_static_type_t) ~> v_static_namespace_t
  =  .immer.detail.rbts.v_generic_ns(position_ns, T(NodeT));

#define position_args: (PS: v_static_namespace_t, VS: v_static_namespace_t,
                        AT: v_static_type_t, RT: v_static_type_t = void) ~> v_static_namespace_t
  =  PS.v_generic_ns(position_args_ns, Q(v_namespace_get_name(VS)), T[AT,RT]);


//---------------------------------------------------------------------
//- empty_regular_pos
//---------------------------------------------------------------------
#define instantiate_empty_regular_pos: (NodeT: v_static_type_t)
{'unit_defn_list'

  namespace position(NodeT)
  {
    struct empty_regular_pos;

    #if (v_guard_ns(empty_regular_pos))

      struct empty_regular_pos
      {
          node_: *NodeT;
      };

      empty_regular_pos.node_t = NodeT;

      alwaysinline
      (_.count): (empty_regular_pos) ~> count_t  =  0;

      alwaysinline
      (_.node): (pos: empty_regular_pos) ~> *NodeT  =  pos.node_;

      alwaysinline
      (_.shift): (empty_regular_pos) ~> shift_t  =  0;

      alwaysinline
      (_.size): (empty_regular_pos) ~> size_t  =  0;


      namespace empty_regular_pos
      {
        #define instantiate_each: (Vis: v_static_namespace_t, ArgsT: v_static_type_t)
        {'unit_defn_list'

          namespace position_args(empty_regular_pos, Vis, ArgsT)
          {
              alwaysinline
              each: (empty_regular_pos, ArgsT) ~> void  {}
          }

        'unit_defn_list'}

        #define instantiate_each_pred: (Vis: v_static_namespace_t, ArgsT: v_static_type_t)
        {'unit_defn_list'

          namespace position_args(empty_regular_pos, Vis, ArgsT, bool)
          {
              alwaysinline
              each_pred: (empty_regular_pos, ArgsT) ~> bool  =  true;
          }

        'unit_defn_list'}

        #define instantiate_visit: (Vis: v_static_namespace_t, ArgsT: v_static_type_t, RetT: v_static_type_t)
        {'unit_defn_list'

          #do (Vis.instantiate_visit_regular(struct {empty_regular_pos; ArgsT;}, RetT))

          namespace position_args(empty_regular_pos, Vis, ArgsT, RetT)
          {
              alwaysinline
              visit: (pos: empty_regular_pos, args: ArgsT) ~> RetT
              {
                  ns = visitor_args(Vis, struct {empty_regular_pos; ArgsT;}, RetT);

                  return  ns.visit_regular({pos, args});
              }
          }

        'unit_defn_list'}

      }     //- namespace empty_regular_pos


      alwaysinline
      make_empty_regular_pos: (node: *NodeT) ~> empty_regular_pos  =  {node};

    #endif

  }     //- namespace position(NodeT)

'unit_defn_list'}


