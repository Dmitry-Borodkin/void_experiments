{ v_import("mainline.void"); }
{ v_enable_mainline(); }
//---------------------------------------------------------------------
{
    v_import("cstdio.void");
    v_import("string.void");

    v_import("refcnt_ptr.void");
}

{ v_import("stack_trace.void"); }
{ voidc_enable_stack_trace(); }


//---------------------------------------------------------------------
#do (std.instantiate_refcnt_ptr(int))


//---------------------------------------------------------------------
{
    p = std.make_refcnt(int);

    *p := 42;

    printf("*p: %d\n", *p);
}


//---------------------------------------------------------------------
#do (std.instantiate_refcnt_ptr(v_string_t))


//---------------------------------------------------------------------
{   p = std.make_refcnt(v_string_t);

    *p := "Превед!";

    *p += " Кагдила?";

    printf("*p: %s\n", p->data);
}


//---------------------------------------------------------------------
#do (std.instantiate_refcnt_ptr(int[]))

{
    p = std.make_refcnt(int[], 5);

    p[0] := 5;
    p[1] := 4;
    p[2] := 3;
    p[3] := 2;
    p[4] := 1;

    printf("p[3]: %d\n", p[3]);
}


//---------------------------------------------------------------------
#do (std.instantiate_refcnt_ptr(int[][2][3]))

{
    p = std.make_refcnt(int[][2][3], 5);

    p[0][0][0] := 5;
    p[1][1][1] := 4;
    p[2][0][2] := 3;
    p[3][1][0] := 2;
    p[4][0][1] := 1;

    printf("p[3][1][0]: %d\n", p[3][1][0]);
}


//---------------------------------------------------------------------
#do (std.instantiate_refcnt_ptr(v_string_t[]))

{
    p = std.make_refcnt(v_string_t[], 3);

    p[0] := "Ыыы33";
    p[1] := "Ыыы22";
    p[2] := "Ыыы11";

    printf("p[1]: %s\n", p[1].data);
}


//---------------------------------------------------------------------









